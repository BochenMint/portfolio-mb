# Link do Calendly / Cal.com — primary CTA (wszystkie przyciski audytu)
VITE_CALENDLY_URL=https://cal.com/twoj-link/audyt

# Backend formularza bez serwera własnego
# Web3Forms: https://web3forms.com → skopiuj Access Key
VITE_FORM_ENDPOINT=https://api.web3forms.com/submit
VITE_FORM_ACCESS_KEY=your-web3forms-access-key

# Alternatywa Formspree — tylko endpoint, bez access key:
# VITE_FORM_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Spline hero — po Publish w spline.design (Export → Publish)
# VITE_SPLINE_RETRO_URL=https://prod.spline.design/xxxx/scene.splinecode
# VITE_SPLINE_TYPE_URL=https://prod.spline.design/xxxx/scene.splinecode
# VITE_SPLINE_ORBIT_URL=https://prod.spline.design/xxxx/scene.splinecode
